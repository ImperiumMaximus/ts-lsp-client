{
  "name": "ts-lsp-client",
  "version": "1.1.1",
  "description": "Standalone Language Server Protocol Implementation with minimal dependencies",
  "files": [
    "build/cjs/**/*",
    "build/esm/**/*",
    "!build/**/*.map"
  ],
  "main": "./build/cjs/main.js",
  "module": "./build/esm/main.js",
  "types": "./build/cjs/types/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./build/esm/types/main.d.ts",
        "default": "./build/esm/main.js"
      },
      "require": {
        "types": "./build/cjs/types/main.d.ts",
        "default": "./build/cjs/main.js"
      }
    }
  },
  "engines": {
    "node": ">= 22.12.0",
    "pnpm": ">= 6.0.0"
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "~24.6.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "nyc": "^17.1.0",
    "prettier": "~3.6.2",
    "rimraf": "~6.1.3",
    "tsutils": "~3.21.0",
    "typescript": "~5.9.3",
    "typescript-language-server": "^3.3.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "start": "node build/src/main.js",
    "clean": "rimraf coverage build tmp",
    "prebuild": "npm run lint",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && node scripts/postbuild.mjs",
    "build:watch": "tsc -w -p tsconfig.release.json",
    "lint": "eslint src/ __tests__/ --ext .ts,.tsx",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "author": "Raffaele Fioratto <raffaele.fioratto@gmail.com>",
  "license": "MIT",
  "repository": "ImperiumMaximus/ts-lsp-client",
  "bugs": "https://github.com/ImperiumMaximus/ts-lsp-client/issues",
  "dependencies": {
    "json-rpc-2.0": "^1.7.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tslib": "~2.8.1"
  },
  "volta": {
    "node": "22.12.0"
  }
}
